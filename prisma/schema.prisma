generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  planned
  active
  completed
}

enum TransactionStatus {
  imported
  categorized
  needs_review
  reviewed
}

enum TransactionDirection {
  income
  expense
}

enum TransactionSource {
  csv
  quickbooks
  demo
}

enum IntegrationProvider {
  quickbooks
}

model Company {
  id                     String                  @id @default(cuid())
  name                   String
  slug                   String                  @unique
  tradeType              String
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  jobs                   Job[]
  transactions           Transaction[]
  uploadBatches          UploadBatch[]
  categoryRules          CategoryRule[]
  integrationConnections IntegrationConnection[]
}

model Job {
  id               String        @id @default(cuid())
  companyId        String
  name             String
  customerName     String
  tradeType        String
  city             String?
  address          String?
  status           JobStatus
  estimatedRevenue Decimal       @db.Decimal(12, 2)
  actualRevenue    Decimal       @db.Decimal(12, 2)
  startDate        DateTime?
  endDate          DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  company          Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transactions     Transaction[]

  @@unique([companyId, name])
  @@index([companyId, status])
  @@index([companyId, createdAt])
}

model Transaction {
  id              String               @id @default(cuid())
  companyId       String
  jobId           String?
  uploadBatchId   String?
  date            DateTime
  description     String
  merchant        String
  memo            String?
  amount          Decimal              @db.Decimal(12, 2)
  direction       TransactionDirection
  fingerprint     String
  rawCategory     String?
  aiCategory      String               @default("Uncategorized")
  confidence      Float                @default(0)
  suggestedJobId  String?
  matchConfidence Float                @default(0)
  matchReason     String?
  status          TransactionStatus    @default(imported)
  source          TransactionSource    @default(csv)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  company         Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job             Job?                 @relation(fields: [jobId], references: [id], onDelete: SetNull)
  uploadBatch     UploadBatch?         @relation(fields: [uploadBatchId], references: [id], onDelete: SetNull)

  @@unique([companyId, fingerprint])
  @@index([companyId, date])
  @@index([companyId, direction, date])
  @@index([companyId, status])
  @@index([jobId])
  @@index([uploadBatchId])
  @@index([suggestedJobId])
}

model UploadBatch {
  id            String        @id @default(cuid())
  companyId     String
  filename      String
  rowCount      Int
  importedCount Int
  invalidCount  Int           @default(0)
  duplicateCount Int          @default(0)
  skippedCount  Int           @default(0)
  incomeTotal   Decimal       @default(0) @db.Decimal(12, 2)
  expenseTotal  Decimal       @default(0) @db.Decimal(12, 2)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transactions  Transaction[]

  @@index([companyId, createdAt])
}

model CategoryRule {
  id        String   @id @default(cuid())
  companyId String
  keyword   String
  category  String
  direction TransactionDirection @default(expense)
  tradeType String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, direction, keyword])
  @@index([companyId, direction])
}

model IntegrationConnection {
  id           String              @id @default(cuid())
  companyId    String
  provider     IntegrationProvider
  accessToken  String?
  refreshToken String?
  realmId      String?
  status       String
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  company      Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, provider])
}
